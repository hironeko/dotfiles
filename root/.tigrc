# tig configuration (v2.5+)

# Keybindings
bind generic q quit
bind status c !git commit
bind main <C-l> refresh

# Graphics
set line-graphics = utf-8

# View settings (v2.5+ compatible)
set main-view = line-number:no,interval:5 id:yes date:relative commit-title:yes,graph,refs,overflow=commit
set blame-view = line-number:yes,interval:5 id:yes date:relative text
set log-view = line-number:yes,interval:5
set diff-view = line-number:yes,interval:5 text

# Pager settings
set pager-view = line-number:yes,interval:5 text
set stage-view = line-number:yes,interval:5 text

# Misc
set ignore-case = true
set ignore-space = some
set tab-size = 4
